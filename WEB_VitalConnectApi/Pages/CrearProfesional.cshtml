@page
@model IndexModel
@{
    ViewData["Title"] = "Crear Profesional";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 bg-body-tertiary">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4 text-info"><i class="bi bi-person-badge me-2"></i>Registrar Profesional</h2>
                    <p class="text-muted mb-5">Ingrese los datos personales y credenciales médicas del profesional.</p>

                    <form method="post">
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control border-0 shadow-sm rounded-3" id="nombre" placeholder="Nombre Completo" required>
                                    <label for="nombre">Nombre Completo</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control border-0 shadow-sm rounded-3" id="ci" placeholder="CI" required>
                                    <label for="ci">Cédula de Identidad</label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control border-0 shadow-sm rounded-3" id="matricula" placeholder="Matrícula" required>
                                    <label for="matricula">Matrícula Profesional</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating mb-3">
                                    <select class="form-select border-0 shadow-sm rounded-3" id="especialidad" required>
                                        <option value="" selected disabled>Seleccione especialidad...</option>
                                        <option value="Medicina General">Medicina General</option>
                                        <option value="Pediatría">Pediatría</option>
                                        <option value="Cardiología">Cardiología</option>
                                        <option value="Ginecología">Ginecología</option>
                                    </select>
                                    <label for="especialidad">Especialidad Médica</label>
                                </div>
                            </div>

                            <div class="col-md-12 mt-4">
                                <button type="submit" class="btn btn-info text-white fw-bold w-100 py-3 rounded-3 shadow-sm">
                                    <i class="bi bi-check-circle me-2"></i>Registrar Médico
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
