<!DOCTYPE html>
<html lang="es" id="mainHtml" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VitalConnect</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <header class="sticky-top mt-3">
        <div class="container">
            <nav class="navbar navbar-expand-lg bg-body-tertiary shadow-sm rounded-4 border px-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold d-flex align-items-center text-info" asp-page="/Index">
                        <i class="bi bi-activity me-2"></i> VitalConnect
                    </a>

                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navVital">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navVital">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link fw-medium" asp-page="/Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-medium" asp-page="/Paciente/Index">Patients</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-medium" asp-page="/Citas/Index">Schedules</a>
                            </li>
                        </ul>

                        <div class="d-none d-lg-flex align-items-center me-3">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-body border-0 rounded-start-pill ps-3">
                                    <i class="bi bi-search text-muted"></i>
                                </span>
                                <input type="text" class="form-control bg-body border-0 rounded-end-pill py-2" style="width: 200px;" placeholder="Search patients...">
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <button class="btn btn-sm btn-outline-secondary rounded-circle p-2" onclick="toggleTheme()" type="button">
                                <i class="bi bi-sun-fill d-none-dark"></i>
                                <i class="bi bi-moon-stars-fill d-none-light"></i>
                            </button>

                            <div class="dropdown">
                                <a href="#" class="d-block link-body-emphasis text-decoration-none" data-bs-toggle="dropdown">
                                    <img src="https://ui-avatars.com/api/?name=Zenon&background=0dcaf0&color=fff" width="35" height="35" class="rounded-circle border">
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-3">
                                    <li><a class="dropdown-item" href="#">Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="#">Logout</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <div class="container my-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto py-4 bg-white border-top">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center small">
                <div class="text-muted">
                    <span class="fw-bold text-dark">VitalConnect</span> Health Systems &copy; 2026
                </div>
                <div class="d-flex gap-4 mt-3 mt-md-0">
                    <a href="#" class="text-muted text-decoration-none">Privacy Policy</a>
                    <a href="#" class="text-muted text-decoration-none">Terms of Service</a>
                    <a href="#" class="text-muted text-decoration-none">Support</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>