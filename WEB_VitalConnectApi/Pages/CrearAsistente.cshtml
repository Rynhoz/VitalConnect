@page
@model IndexModel
@{
    ViewData["Title"] = "Crear Asistente";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 bg-body-tertiary">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4 text-info"><i class="bi bi-person-gear me-2"></i>Registrar Asistente</h2>
                    <p class="text-muted mb-5">Complete la información para el personal de apoyo administrativo.</p>

                    <form method="post">
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control border-0 shadow-sm rounded-3" id="nombreAsistente" placeholder="Nombre Completo" required>
                                    <label for="nombreAsistente">Nombre Completo</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control border-0 shadow-sm rounded-3" id="ciAsistente" placeholder="CI" required>
                                    <label for="ciAsistente">Cédula de Identidad</label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <select class="form-select border-0 shadow-sm rounded-3" id="turno" required>
                                        <option value="" selected disabled>Seleccione turno...</option>
                                        <option value="Mañana">Mañana (08:00 - 12:00)</option>
                                        <option value="Tarde">Tarde (14:00 - 18:00)</option>
                                        <option value="Noche">Noche (18:00 - 22:00)</option>
                                    </select>
                                    <label for="turno">Turno Asignado</label>
                                </div>
                            </div>

                            <div class="col-md-12 mt-4">
                                <button type="submit" class="btn btn-info text-white fw-bold w-100 py-3 rounded-3 shadow-sm">
                                    <i class="bi bi-save me-2"></i>Finalizar Registro
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>