@page
@model ErrorModel
@{
    Layout = null;
    ViewData["Title"] = "Error 7w7 | VitalConnect";
}

<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            /* Usamos el mismo color de fondo que Bootstrap Dark */
            background-color: #212529;
            color: #dee2e6;
            min-height: 100vh;
        }

        .card-error {
            background-color: #2b3035; /* Un tono ligeramente más claro que el fondo */
            border: 1px solid #495057;
            max-width: 500px;
            width: 100%;
        }

        .btn-vital {
            background-color: #0dcaf0; /* El color info de tu navbar */
            color: #000;
            font-weight: 600;
            border: none;
            transition: all 0.2s ease;
        }

            .btn-vital:hover {
                background-color: #31d2f2;
                transform: translateY(-1px);
            }

        .trace-box {
            background-color: #1a1d20;
            font-family: 'Consolas', monospace;
            font-size: 0.8rem;
            color: #adb5bd;
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center p-3">

    <div class="card-error shadow-lg rounded-4 p-5 text-center">

        <div class="mb-4">
            <i class="bi bi-exclamation-triangle text-info" style="font-size: 3rem;"></i>
        </div>

        <h1 class="h3 fw-bold mb-3">Error del Sistema</h1>

        <p class="text-secondary mb-5">
            Lo sentimos, hemos encontrado una dificultad técnica inesperada. El incidente ha sido registrado para su revisión.
        </p>

        <div class="d-grid gap-2">
            <a asp-page="/Index" class="btn btn-vital rounded-pill py-2">
                <i class="bi bi-arrow-left me-2"></i>Volver al Inicio
            </a>
            <a href="mailto:support@vitalconnect.com" class="btn btn-link text-info text-decoration-none small mt-2">
                Reportar este problema
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="mt-5 pt-4 border-top border-secondary border-opacity-25">
                <div class="trace-box p-2 rounded-3">
                    <span class="text-uppercase small fw-bold">ID de Seguimiento:</span><br />
                    <code>@Model.RequestId</code>
                </div>
            </div>
        }
    </div>

</body>
</html>