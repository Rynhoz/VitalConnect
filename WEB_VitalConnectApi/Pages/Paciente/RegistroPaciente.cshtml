@page "/Paciente/Index"
@model WEB_VitalConnectApi.Pages.Paciente.PacienteModel
@{
    ViewData["Title"] = "Inicio Paciente";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body text-center">
            <img src="https://via.placeholder.com/120"
                 class="rounded-circle mb-3"
                 alt="Paciente">

            <h3>@Model.NombrePaciente</h3>
            <p class="text-muted">Paciente registrado</p>
        </div>
    </div>

    <div class="accordion mt-4" id="pacienteAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#datos">
                    Mis Datos
                </button>
            </h2>
            <div id="datos" class="accordion-collapse collapse show">
                <div class="accordion-body">
                    <p><strong>CI:</strong> @Model.CI</p>
                    <p><strong>Celular:</strong> @Model.Celular</p>
                    <p><strong>Dirección:</strong> @Model.Direccion</p>
                    <p><strong>Alergias:</strong> @Model.Alergias</p>
                </div>
            </div>
        </div>

        <div class="accordion-item mt-2">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#cita">
                    Próxima Cita
                </button>
            </h2>
            <div id="cita" class="accordion-collapse collapse">
                <div class="accordion-body">
                    <p><strong>Fecha:</strong> @Model.ProximaFecha</p>
                    <p><strong>Hora:</strong> @Model.ProximaHora</p>
                    <p><strong>Médico:</strong> @Model.Medico</p>
                </div>
            </div>
        </div>
    </div>
</div>