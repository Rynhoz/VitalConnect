@page
@model WEB_VitalConnectApi.Pages.ListaModel
@{
    ViewData["Title"] = "Gestión de Profesionales";
}

<div class="container mt-4">
    <div class="card shadow rounded-4 p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <div>
                <h2 class="mb-1">Gestión de Médicos Profesionales</h2>
                <p class="text-muted mb-0">Consulta, cambia estado y elimina profesionales médicos</p>
            </div>

            <a asp-page="/CrearProfesional" class="btn btn-info text-white fw-bold">
                <i class="bi bi-plus-lg me-2"></i>Registrar Médico
            </a>
        </div>

        <form method="get" class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="form-label">Filtrar por Especialidad</label>
                <select asp-for="FiltroEspecialidad" class="form-select">
                    <option value="">Todas las Especialidades</option>
                    <option value="Medicina General">Medicina General</option>
                    <option value="Pediatría">Pediatría</option>
                    <option value="Cardiología">Cardiología</option>
                    <option value="Ginecología">Ginecología</option>
                </select>
            </div>

            <div class="col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-success">Buscar</button>
                <a asp-page="/Lista" class="btn btn-outline-secondary">Limpiar</a>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(Model.Mensaje))
        {
            <div class="alert alert-info">
                @Model.Mensaje
            </div>
        }

        @if (Model.Profesionales != null && Model.Profesionales.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nombre Completo</th>
                            <th>Especialidad</th>
                            <th>Matrícula</th>
                            <th>CI</th>
                            <th>Estado</th>
                            <th style="width: 280px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Profesionales)
                        {
                            <tr>
                                <td>@p.ID</td>
                                <td class="fw-bold">@p.NombreCompleto</td>
                                <td><span class="badge bg-info text-white rounded-pill px-3">@p.Especialidad</span></td>
                                <td>@p.MatriculaProfesional</td>
                                <td>@p.CI</td>
                                <td>
                                    @if (p.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-page="/CrearProfesional"
                                           asp-route-id="@p.ID"
                                           class="btn btn-warning btn-sm">
                                            Editar
                                        </a>

                                        <form method="post" asp-page-handler="CambiarEstado">
                                            <input type="hidden" name="id" value="@p.ID" />
                                            <button type="submit" class="btn btn-secondary btn-sm">
                                                Estado
                                            </button>
                                        </form>

                                        <form method="post" asp-page-handler="Eliminar">
                                            <input type="hidden" name="id" value="@p.ID" />
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>