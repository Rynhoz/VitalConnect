@page
@model WEB_VitalConnectApi.Pages.ListaModel
@{
    ViewData["Title"] = "Gestión de Personal";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="fw-bold m-0">Gestión de Personal</h1>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-5">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-info m-0"><i class="bi bi-hospital me-2"></i>Médicos Profesionales</h5>
            <a asp-page="/CrearProfesional" class="btn btn-info text-white fw-bold rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Agregar Médico
            </a>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th>Nombre</th>
                            <th>Especialidad</th>
                            <th>Matrícula</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Profesionales)
                        {
                            <tr>
                                <td class="fw-bold">@p.NombreCompleto</td>
                                <td><span class="badge bg-info-subtle text-info rounded-pill px-3">@p.Especialidad</span></td>
                                <td class="text-muted">@p.MatriculaProfesional</td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="InactivarProfesional" asp-route-id="@p.CI" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle p-2" title="Marcar como Inactivo">
                                            <i class="bi bi-person-x-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-info m-0"><i class="bi bi-headset me-2"></i>Personal Asistente</h5>
            <a asp-page="/CrearAsistente" class="btn btn-info text-white fw-bold rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Agregar Asistente
            </a>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th>Nombre</th>
                            <th>Turno</th>
                            <th>CI</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.Asistentes)
                        {
                            <tr>
                                <td class="fw-bold">@a.NombreCompleto</td>
                                <td><span class="badge bg-warning-subtle text-warning rounded-pill px-3">@a.Turno</span></td>
                                <td>@a.CI</td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="InactivarAsistente" asp-route-id="@a.CI" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle p-2" title="Marcar como Inactivo">
                                            <i class="bi bi-person-x-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>