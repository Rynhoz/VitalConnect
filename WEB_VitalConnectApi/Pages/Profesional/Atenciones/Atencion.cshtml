@page
@model AtencionModel
@{
    ViewData["Title"] = "Atenciones";
}

<div class="container mt-4">
    <div class="card shadow rounded-4 p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <div>
                <h2 class="mb-1">Gestión de Atenciones</h2>
                <p class="text-muted mb-0">Consulta, edita y elimina atenciones registradas</p>
            </div>

            <a asp-page="/Profesional/Atenciones/Registrar" class="btn btn-primary">
                Registrar Atención
            </a>
        </div>

        <form method="get" class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label">Filtrar por ID Cita</label>
                <input asp-for="FiltroIdCita" type="number" min="1" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Filtrar por fecha</label>
                <input asp-for="FiltroFecha" type="date" class="form-control" />
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-success">Buscar</button>
                <a asp-page="/Profesional/Atenciones/Atenciones" class="btn btn-outline-secondary">Limpiar</a>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(Model.Mensaje))
        {
            <div class="alert alert-info">
                @Model.Mensaje
            </div>
        }

        @if (Model.ListaAtenciones != null && Model.ListaAtenciones.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Diagnóstico</th>
                            <th>Tratamiento</th>
                            <th>ID Cita</th>
                            <th>Estado</th>
                            <th style="width:260px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var atencion in Model.ListaAtenciones)
                        {
                            <tr>
                                <td>@atencion.ID</td>
                                <td>@atencion.FechaAtencion.ToString("dd/MM/yyyy")</td>
                                <td>@atencion.Diagnostico</td>
                                <td>@atencion.Tratamiento</td>
                                <td>@atencion.IdCita</td>
                                <td>
                                    @if (atencion.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-page="/Profesional/Atenciones/Registrar"
                                           asp-route-id="@atencion.ID"
                                           class="btn btn-warning btn-sm">
                                            Editar
                                        </a>

                                        <form method="post" asp-page-handler="Eliminar">
                                            <input type="hidden" name="id" value="@atencion.ID" />
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                Eliminar
                                            </button>
                                        </form>

                                        <form method="post" asp-page-handler="CambiarEstado">
                                            <input type="hidden" name="id" value="@atencion.ID" />
                                            <button type="submit" class="btn btn-secondary btn-sm">
                                                Estado
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                No hay atenciones registradas.
            </div>
        }
    </div>
</div>
