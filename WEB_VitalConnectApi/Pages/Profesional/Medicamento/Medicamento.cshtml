@page
@model WEB_VitalConnectApi.Pages.Profesional.Medicamento.MedicamentoModel
@{
    ViewData["Title"] = "Gestión de Inventario - Medicamentos";
}

<div class="container mt-4">
    <div class="card shadow rounded-4 p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <div>
                <h2 class="mb-1 text-info"><i class="bi bi-capsule me-2"></i>Gestión de Medicamentos</h2>
                <p class="text-muted mb-0">Administra el inventario y disponibilidad de fármacos.</p>
            </div>
            <a asp-page="Agregar" class="btn btn-info text-white fw-bold rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Nuevo Medicamento
            </a>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center rounded-3">
                    <h6 class="text-muted small text-uppercase fw-bold">Total en Sistema</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalMedicamentos</h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-success-subtle p-3 text-center rounded-3">
                    <h6 class="text-success small text-uppercase fw-bold">Disponibles</h6>
                    <h2 class="fw-bold text-success mb-0">@Model.Activos</h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-danger-subtle p-3 text-center rounded-3">
                    <h6 class="text-danger small text-uppercase fw-bold">No Disponibles</h6>
                    <h2 class="fw-bold text-danger mb-0">@Model.Inactivos</h2>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%">Nombre</th>
                        <th style="width: 40%">Descripción</th>
                        <th style="width: 15%">Estado</th>
                        <th style="width: 20%" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Medicamentos != null && Model.Medicamentos.Any())
                    {
                        foreach (var m in Model.Medicamentos)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@m.Nombre</td>
                                <td class="text-muted small">@m.Descripcion</td>
                                <td>
                                    @if (m.Estado)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-3">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <form method="post" asp-page-handler="CambiarEstado" asp-route-id="@m.MedicamentoId">
                                            <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm">
                                                <i class="bi bi-arrow-repeat me-1"></i> Estado
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-box-seam display-4 text-body-tertiary"></i>
                                <p class="text-muted mt-2">No se encontraron medicamentos registrados.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>