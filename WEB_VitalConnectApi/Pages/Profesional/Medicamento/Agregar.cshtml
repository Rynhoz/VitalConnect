@page
@model AgregarModel
@{
    ViewData["Title"] = "Agregar medicamento";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow rounded-4">

                <div class="card-header bg-white border-0">
                    <h4 class="fw-bold mb-0">Nuevo Medicamento</h4>
                    <small class="text-muted">Registrar medicamento en el sistema</small>
                </div>

                
                <div class="card-body">

                    <form method="post">

                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input asp-for="Medicamento.Nombre" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea asp-for="Medicamento.Descripcion" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Medicamento.Estado" class="form-check-input" />
                            <label class="form-check-label">Activo</label>
                        </div>

                        <div class="d-grid">
                            <button class="btn btn-success">
                                Guardar Medicamento
                            </button>
                        </div>

                    </form>

                </div>

            </div>

            <div class="mt-3 text-center">
                <a asp-page="Medicamento" class="btn btn-outline-secondary">
                    ← Volver
                </a>
            </div>

        </div>

    </div>

</div>
