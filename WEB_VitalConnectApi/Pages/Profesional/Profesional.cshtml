@page
@model Pages.Profesional.ProfesionalModel
@{
    ViewData["Title"] = "Inicio Profesional";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-4">Panel del Médico</h2>

    <div class="row g-4">

        <div class="col-md-6">
            <div class="card shadow rounded-4 p-4">
                <h6 class="text-muted">Citas de hoy</h6>
                <h1 class="fw-bold">@Model.CitasHoy</h1>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow rounded-4 p-4">
                <h6 class="text-muted">Pacientes atendidos (7 días)</h6>
                <h1 class="fw-bold">@Model.PacientesSemana</h1>
            </div>
        </div>

    </div>

</div>
