@page
@model WEB_VitalConnectApi.Pages.GestionModel
@{
    ViewData["Title"] = "Gestión de Citas";
}

<div class="container mt-4">
    <div class="card shadow rounded-4 p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <div>
                <h2 class="mb-1">Gestión de Citas</h2>
                <p class="text-muted mb-0">Registrar, editar, eliminar y cambiar estado</p>
            </div>
            <a asp-page="/Profesional/Citas/Agenda" class="btn btn-outline-primary">
                Ver Agenda
            </a>
        </div>

        @if (!string.IsNullOrEmpty(Model.Mensaje))
        {
            <div class="alert alert-info">
                @Model.Mensaje
            </div>
        }

        <form method="post" class="row g-3 mb-4">
            <input asp-for="Formulario.CitaId" type="hidden" />

            <div class="col-md-4">
                <label class="form-label">Fecha</label>
                <input asp-for="Formulario.Fecha" type="date" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Hora</label>
                <input asp-for="Formulario.Hora" class="form-control" placeholder="08:00" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Estado de Cita</label>
                <select asp-for="Formulario.EstadoCita" class="form-select">
                    <option value="">Seleccione</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Confirmada">Confirmada</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Id Paciente</label>
                <input asp-for="Formulario.IdPaciente" type="number" min="1" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Id Profesional</label>
                <input asp-for="Formulario.IdProfesional" type="number" min="1" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Id Asistente</label>
                <input asp-for="Formulario.IdAsistente" type="number" min="1" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Activo</label>
                <select asp-for="Formulario.Estado" class="form-select">
                    <option value="true">Sí</option>
                    <option value="false">No</option>
                </select>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    @(Model.Formulario.CitaId > 0 ? "Actualizar Cita" : "Registrar Cita")
                </button>

                <a asp-page="/Profesional/Citas/Gestion" class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>
        </form>

        @if (Model.Citas != null && Model.Citas.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Estado Cita</th>
                            <th>Activo</th>
                            <th>Paciente</th>
                            <th>Profesional</th>
                            <th>Asistente</th>
                            <th style="width: 250px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cita in Model.Citas)
                        {
                            <tr>
                                <td>@cita.CitaId</td>
                                <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@cita.Hora</td>
                                <td>@cita.EstadoCita</td>
                                <td>
                                    @if (cita.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>@cita.IdPaciente</td>
                                <td>@cita.IdProfesional</td>
                                <td>@(cita.IdAsistente.HasValue? cita.IdAsistente.ToString() : "Sin asignar")</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <form method="post" asp-page-handler="Editar">
                                            <input type="hidden" name="id" value="@cita.CitaId" />
                                            <button type="submit" class="btn btn-warning btn-sm">Editar</button>
                                        </form>

                                        <form method="post" asp-page-handler="CambiarEstado">
                                            <input type="hidden" name="id" value="@cita.CitaId" />
                                            <button type="submit" class="btn btn-secondary btn-sm">Estado</button>
                                        </form>

                                        <form method="post" asp-page-handler="Eliminar">
                                            <input type="hidden" name="id" value="@cita.CitaId" />
                                            <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                No hay citas registradas.
            </div>
        }
    </div>
</div>